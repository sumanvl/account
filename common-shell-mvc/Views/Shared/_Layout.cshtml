@{
    var pageTitle = ViewData["Title"] as string ?? "JNS Accounting Solutions";
    var pageDescription = ViewData["Description"] as string ?? "Accountant, auditor, tax consultant and accounting solutions support in Coimbatore.";
}
<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@pageTitle</title>
    <meta name="description" content="@pageDescription" />
    <link rel="icon" href="@Url.Content("~/assets/favicon.svg")" type="image/svg+xml" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" />
    <link rel="stylesheet" href="@Url.Content("~/assets/css/common-shell.css")" />
    @RenderSection("Styles", required: false)
</head>
<body>
    @await Html.PartialAsync("_Header")
    <main id="main-content">
        @RenderBody()
    </main>
    @await Html.PartialAsync("_Footer")
    <script src="@Url.Content("~/assets/js/common-shell.js")"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
